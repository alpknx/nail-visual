# Postgres connection string (PostGIS required - see docker-compose.yml)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nail_visual

# NextAuth - generate a fresh secret with `openssl rand -base64 32`, never
# reuse a placeholder/example value here
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# Set to true only if deployed behind a trusted reverse proxy (e.g. Vercel)
AUTH_TRUST_HOST=

# UploadThing (https://uploadthing.com) - required for image uploads
UPLOADTHING_TOKEN=

# Optional: Upstash Redis (https://upstash.com, free tier) for real
# cross-instance rate limiting on login/register. Falls back to an
# in-memory limiter (fine for local dev, not for multi-instance prod) if
# either of these is unset.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Telegram Bot API (https://t.me/BotFather) - powers guest booking
# confirmation and post-session review requests, replacing the old email
# flow. TELEGRAM_BOT_TOKEN is the secret bot token from BotFather.
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME is the bot's @username (no @, no t.me/) -
# used client-side to build the deep link shown to guests after booking.
# TELEGRAM_WEBHOOK_SECRET is a random string you choose; set the same value
# when registering the webhook with Telegram (secret_token param) - the
# webhook route rejects requests missing this header. CRON_SECRET protects
# the /api/cron/session-followup route the same way (Vercel sets the
# Authorization header automatically for its own Cron Jobs).
TELEGRAM_BOT_TOKEN=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
CRON_SECRET=

# Optional: PostHog analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Optional: Sentry error tracking/monitoring (https://sentry.io - create a
# free project, choose the Next.js platform, and copy its DSN). Leave unset
# to disable Sentry entirely; the app builds and runs fine without it.
# SENTRY_DSN is used by the server/edge runtime init, NEXT_PUBLIC_SENTRY_DSN
# by the browser init - both should be set to the same DSN value.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Optional: only needed in CI/build environments that upload source maps to
# Sentry (requires an auth token from sentry.io/settings/account/api/auth-tokens/)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
